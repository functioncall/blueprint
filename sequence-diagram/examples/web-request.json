{
  "title": "Web request — cached read",
  "subtitle": "browser → API → cache, falling back to the DB",
  "meta": { "created": "2026-06-26", "updated": "2026-06-27" },
  "actors": [
    { "id": "user", "label": "User", "zone": "user", "sub_caption": "browser" },
    { "id": "web", "label": "Web", "zone": "client", "sub_caption": "Next.js" },
    { "id": "api", "label": "API", "zone": "server", "sub_caption": "/v1" },
    { "id": "cache", "label": "Redis", "zone": "cache" },
    { "id": "db", "label": "Postgres", "zone": "database" }
  ],
  "messages": [
    { "phase": "REQUEST" },
    { "from": "user", "to": "web", "text": "click Buy", "paths": ["read"] },
    { "from": "web", "to": "api", "text": "GET /order/42", "via": "api", "paths": ["read"],
      "src": "app/order/page.tsx → routes.ts" },
    { "from": "api", "to": "cache", "text": "read order", "caption": "key order:42", "via": "io" },
    { "from": "cache", "to": "api", "text": "miss", "kind": "ret" },
    { "phase": "FALLBACK" },
    { "from": "api", "to": "db", "text": "query order", "caption": "id 42", "via": "io", "metrics": { "latency_ms": 35 } },
    { "from": "db", "to": "api", "text": "row", "kind": "ret", "metrics": { "latency_ms": 35 } },
    { "from": "api", "to": "cache", "text": "cache order", "caption": "ttl 60s", "via": "io" },
    { "from": "api", "to": "web", "text": "200 OK", "caption": "order json", "kind": "ret", "paths": ["read"] },
    { "from": "web", "to": "user", "text": "render order", "kind": "ret", "paths": ["read"] }
  ],
  "fragments": [
    { "kind": "opt", "label": "cache miss", "range": [4, 6] }
  ]
}
