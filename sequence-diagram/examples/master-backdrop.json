{
  "project": "Backdrop",
  "provenance": { "git_sha": "bbf49c3ac8e2c3a321835e20cc3bd4c41acb0ad5" },
  "scenarios": [
    {
      "id": "capture",
      "title": "Press-and-hold capture with voice note",
      "subtitle": "still + narration → server STT → vision enrich → live result",
      "meta": { "created": "2026-06-26", "updated": "2026-06-26", "status": "verified" },
      "source_paths": ["Packages/BackdropEnrichment/Sources/BackdropEnrichment", "Packages/BackdropAR/Sources/BackdropAR"],
      "actors": [
        { "id": "user", "label": "User", "zone": "user", "sub_caption": "person" },
        { "id": "phone", "label": "Phone", "kind": "internal", "zone": "client",
          "sub": [ { "id": "ui", "label": "Camera UI" },
                   { "id": "rec", "label": "Narration" },
                   { "id": "up", "label": "Upload" } ] },
        { "id": "firebase", "label": "Firebase", "kind": "external", "zone": "firebase",
          "sub": [ { "id": "st", "label": "Storage" },
                   { "id": "fs", "label": "Firestore" } ] },
        { "id": "srv", "label": "Server", "zone": "server", "sub_caption": "/capture/enrich" },
        { "id": "whisper", "label": "Whisper", "zone": "whisper", "sub_caption": "OpenAI whisper-1" },
        { "id": "claude", "label": "Claude", "zone": "claude", "sub_caption": "Anthropic Haiku" }
      ],
      "messages": [
        { "phase": "CAPTURE" },
        { "from": "user", "to": "phone.ui", "text": "press & hold capture", "paths": ["capture"] },
        { "self": "phone.ui", "text": "freeze still → base64 JPEG" },
        { "from": "phone.ui", "to": "phone.rec", "text": "start narration (mic perm)", "paths": ["capture"] },
        { "self": "phone.rec", "text": "mic → AAC .m4a · RMS ring · 60s cap" },
        { "from": "user", "to": "phone.rec", "text": "release finger" },
        { "from": "phone.rec", "to": "phone.ui", "text": "audio file + speechDetected", "kind": "ret" },
        { "from": "phone.ui", "to": "user", "text": "Save view (still + audiogram)", "kind": "ret" },
        { "phase": "SAVE" },
        { "from": "user", "to": "phone.ui", "text": "tap SAVE", "paths": ["capture"] },
        { "from": "phone.ui", "to": "phone.up", "text": "accept(still, audio)", "paths": ["capture"] },
        { "from": "phone.up", "to": "firebase.st", "text": "upload still + audio blobs", "paths": ["capture"],
          "src": "CaptureUploadService.swift" },
        { "from": "phone.up", "to": "firebase.fs", "text": "write source (status: uploading)" },
        { "phase": "SERVER · ENRICH" },
        { "from": "phone.up", "to": "srv", "text": "POST /capture/enrich + ID token", "paths": ["capture", "enrich"],
          "src": "EnrichClient.swift → capture.routes.ts" },
        { "self": "srv", "text": "quota check · reserve cap" },
        { "from": "srv", "to": "firebase.st", "text": "read audio blob" },
        { "from": "firebase.st", "to": "srv", "text": "m4a bytes", "kind": "ret" },
        { "from": "srv", "to": "whisper", "text": "transcribe (whisper-1)", "paths": ["enrich"],
          "metrics": { "cost": 0.006, "latency_ms": 1400 }, "src": "openai-stt.client.ts" },
        { "from": "whisper", "to": "srv", "text": "transcript text", "kind": "ret",
          "metrics": { "cost": 0.006, "latency_ms": 1400 } },
        { "self": "srv", "text": "write narration · delete audio" },
        { "from": "srv", "to": "firebase.st", "text": "read still blob" },
        { "from": "firebase.st", "to": "srv", "text": "JPEG bytes", "kind": "ret" },
        { "from": "srv", "to": "claude", "text": "vision: narration + image", "paths": ["enrich"],
          "metrics": { "cost": 0.011, "latency_ms": 900 }, "src": "claude-vision-enricher.ts" },
        { "from": "claude", "to": "srv", "text": "title · blurb · category · OCR", "kind": "ret",
          "metrics": { "cost": 0.011, "latency_ms": 900 } },
        { "from": "srv", "to": "firebase.fs", "text": "write enrichment (status: ready)", "paths": ["enrich"] },
        { "note": "srv", "text": "enqueue wiki compile (batched → Claude)" },
        { "from": "firebase.fs", "to": "phone.ui", "text": "listener: source ready", "kind": "ret" },
        { "from": "phone.ui", "to": "user", "text": "show enriched result (ItemHero)", "kind": "ret", "paths": ["capture"] }
      ],
      "fragments": [
        { "kind": "opt", "label": "voice note present", "range": [13, 17] }
      ]
    }
  ]
}
